  "info": {
    "_postman_id": "7a8f89d6-4c02-4f50-8c3e-6b8cd6b8f001",
    "name": "Pets API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const requestName = (pm.info.requestName || '').toLowerCase();",
          "let responseBody = null;",
          "try {",
          "  responseBody = pm.response.json();",
          "} catch (error) {",
          "  responseBody = null;",
          "}",
          "",
          "function expectStatus(expectedStatus) {",
          "  pm.test('Status code is ' + expectedStatus, function () {",
          "    pm.response.to.have.status(expectedStatus);",
          "  });",
          "}",
          "",
          "function expectArrayNotEmpty() {",
          "  pm.test('Response body is a non-empty array', function () {",
          "    pm.expect(responseBody).to.be.an('array');",
          "    pm.expect(responseBody.length).to.be.greaterThan(0);",
          "  });",
          "}",
          "",
          "function expectObjectId() {",
          "  pm.test('Response body contains an id', function () {",
          "    pm.expect(responseBody).to.be.an('object');",
          "    pm.expect(responseBody).to.have.property('id');",
          "  });",
          "}",
          "",
          "function saveCreatedId(variableName) {",
          "  if (responseBody && typeof responseBody === 'object' && responseBody.id !== undefined && responseBody.id !== null) {",
          "    pm.globals.set(variableName, String(responseBody.id));",
          "  }",
          "}",
          "",
          "if (/^test api status$/.test(requestName)) {",
          "  expectStatus(200);",
          "}",
          "if (/^create adopter$/.test(requestName)) { expectStatus(201); saveCreatedId('adopterId'); expectObjectId(); }",
          "if (/^create shelter$/.test(requestName)) { expectStatus(201); saveCreatedId('shelterId'); expectObjectId(); }",
          "if (/^create pet$/.test(requestName)) { expectStatus(201); saveCreatedId('petId'); expectObjectId(); }",
          "",
          "if (/^get all /.test(requestName) || /^get pets$/.test(requestName) || /^get adopters$/.test(requestName) || /^get shelters$/.test(requestName)) {",
          "  expectStatus(200);",
          "  expectArrayNotEmpty();",
          "}",
          "",
          "if (/^get .* by id$/.test(requestName) || /^get .* detail$/.test(requestName)) {",
          "  expectStatus(200);",
          "  expectObjectId();",
          "}",
          "",
          "if (/^update /.test(requestName)) { expectStatus(200); }",
          "if (/^delete /.test(requestName)) { expectStatus(204); }",
          "",
          "const globalIdChecks = [",
          "  ['adopter', 'adopterId'],",
          "  ['shelter', 'shelterId'],",
          "  ['pet', 'petId']",
          "];",
          "for (const [token, variableName] of globalIdChecks) {",
          "  if (requestName.includes(token)) {",
          "    const storedId = pm.globals.get(variableName);",
          "    if (storedId && responseBody && typeof responseBody === 'object' && responseBody.id !== undefined) {",
          "      pm.test('Response id matches ' + variableName, function () {",
          "        pm.expect(String(responseBody.id)).to.eql(String(storedId));",
          "      });",
          "    }",
          "  }",
          "}"
        ]
      }
    }
  ],
